{
  "mcpServers": {
    "shadcn": {
      "command": "bunx",
      "args": [
        "shadcn@latest",
        "mcp",
        "-c",
        "web"
      ]
    },
    "svelte": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "-y",
        "@sveltejs/mcp"
      ],
      "env": {}
    }
  }
}